#
# Environment switch:
#
# - ENV=DEV  → API URL defaults to `http://127.0.0.1:5001/api`
# - ENV=PROD → API URL defaults to `https://prmsc-mrv.vercel.app/api`
#
# Set one:
ENV=PROD
# ENV=PROD
#
# Optional override (host-only is OK; `/api` is auto-appended if missing):
# API_URL=http://127.0.0.1:5001
# API_URL=https://prmsc-mrv.vercel.app/api
API_URL=https://prmsc-mrv-api.vercel.app/api
