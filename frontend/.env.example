# Copy to `.env` for local development (Vite reads `VITE_*` at build time).

# Environment switch:
# - VITE_ENV=DEV  → defaults to http://127.0.0.1:5001/api
# - VITE_ENV=PROD → defaults to https://prmsc-mrv-api.vercel.app//api
VITE_ENV=DEV

# Base URL for JSON API — must include `/api` path (no trailing slash after `api`).
# Examples:
#   VITE_API_URL=http://127.0.0.1:5001
#   VITE_API_URL=https://your-api.example.com/api
# Optional override; if set without `/api`, the app will append it.
VITE_API_URL=

# Vercel: set Root Directory to `frontend`. In Project → Settings → Environment Variables,
# add at least VITE_API_URL. Use different values for Preview vs Production if needed.
# VITE_* are inlined at build time.

# HQ map uses OpenStreetMap (no API key).
