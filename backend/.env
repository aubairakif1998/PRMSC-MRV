# ── Flask Security Keys ───────────────────────────────────────
# Generate secure keys with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-change-me-in-production-use-secrets-token-hex
JWT_SECRET_KEY=jwt-dev-change-me-in-production-use-secrets-token-hex

# ── Flask Environment ─────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── CORS (comma-separated; browser origin must match exactly) ─
