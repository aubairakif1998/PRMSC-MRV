# Copy to .env.production and fill secrets. Never commit .env.production.
# Supabase project: https://supabase.com/dashboard/project/hyadnyrczyftkgdqyjhr

FLASK_ENV=production
FLASK_DEBUG=0

SECRET_KEY=replace-with-secrets-token-hex-32-bytes
JWT_SECRET_KEY=replace-with-different-secrets-token-hex-32-bytes

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.hyadnyrczyftkgdqyjhr.supabase.co:5432/postgres

SUPABASE_URL=https://hyadnyrczyftkgdqyjhr.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_PROJECT_ID=hyadnyrczyftkgdqyjhr
SUPABASE_STORAGE_BUCKET=mrv-public
SUPABASE_S3_ENDPOINT=https://hyadnyrczyftkgdqyjhr.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# Required in production: comma-separated browser Origins (scheme + host, no trailing slash).
# List every frontend that calls this API (e.g. Render static site + local dev if needed).
CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173
