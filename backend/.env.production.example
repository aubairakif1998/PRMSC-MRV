# ─────────────────────────────────────────────────────────────
# MRV Backend — Production environment (copy to .env.production)
# ─────────────────────────────────────────────────────────────
# Usage:
#   cp .env.production.example .env.production
#   # edit .env.production with real secrets; never commit .env.production
#
# Load order: .env is loaded first, then .env.production (if present) overrides.
# For production-only hosts you can ship only .env.production (no .env).
#
# Secrets: python -c "import secrets; print(secrets.token_hex(32))"
# DB URI: Supabase Dashboard → Settings → Database → Connection string (URI), pooler port 6543 for serverless.
# ─────────────────────────────────────────────────────────────

# ── Flask (production) ───────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0

# ── Security (required; replace placeholders) ──────────────────
SECRET_KEY=replace-with-secrets-token-hex-32-bytes
JWT_SECRET_KEY=replace-with-different-secrets-token-hex-32-bytes

# ── Database (Supabase PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Supabase project & storage (S3-compatible API) ────────────
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_STORAGE_BUCKET=mrv-public
SUPABASE_S3_ENDPOINT=https://[project-ref].storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# Optional: override public object URLs (defaults to ${SUPABASE_URL}/storage/v1/object/public)
# SUPABASE_STORAGE_PUBLIC_BASE_URL=https://[project-ref].supabase.co/storage/v1/object/public

# Frontend origins (comma-separated). Replace https://app.yourdomain.com with your real URL.
# Localhost entries are optional; include them if you run the API locally against this file.
CORS_ORIGINS=https://app.yourdomain.com,http://localhost:5173,http://127.0.0.1:5173
