# Local development — copy to .env and fill values.
# Production template (safe to commit): see .env.production.example → copy to .env.production

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# ── Database (Supabase PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# ── Supabase Storage (S3-compatible) ───────────────────────────
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_STORAGE_BUCKET=mrv-public
SUPABASE_S3_ENDPOINT=https://[project-ref].storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key

# Optional
# SUPABASE_STORAGE_PUBLIC_BASE_URL=https://[project-ref].supabase.co/storage/v1/object/public

# CORS (comma-separated; omit to use localhost dev defaults including :5173)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://app.example.com
